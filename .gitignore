# Java / Maven
target/
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
.vscode/
.settings/
.classpath
.project

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl is deliberately NOT ignored. HashiCorp's guidance is to
# commit it: it pins provider versions and their checksums, so `terraform init`
# resolves identically on another machine or in CI. Ignoring it means two people
# running the same config can get different providers.

# Env files
.env
.env.local

# Kubernetes secrets (never commit real secrets)
*-secret.yaml
